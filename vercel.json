{
  "installCommand": "cd frontend && pnpm install && cd ../backend && pnpm install",
  "buildCommand": "cd frontend && pnpm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
